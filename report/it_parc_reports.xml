<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========== RAPPORT 1 : Fiche Équipement ========== -->
    <record id="action_report_it_equipement" model="ir.actions.report">
        <field name="name">Fiche Équipement</field>
        <field name="model">it.equipement</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_parc.report_it_equipement_template</field>
        <field name="report_file">it_parc.report_it_equipement_template</field>
        <field name="binding_model_id" ref="model_it_equipement"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_it_equipement_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center mb-4">Fiche Équipement</h2>
                        <table class="table table-bordered">
                            <tr><th>Référence</th><td><t t-esc="doc.reference or '-'"/></td></tr>
                            <tr><th>Nom</th><td><t t-esc="doc.name"/></td></tr>
                            <tr><th>Type</th><td><t t-esc="doc.type_equipement"/></td></tr>
                            <tr><th>Marque</th><td><t t-esc="doc.marque or '-'"/></td></tr>
                            <tr><th>Modèle</th><td><t t-esc="doc.modele or '-'"/></td></tr>
                            <tr><th>Numéro de Série</th><td><t t-esc="doc.numero_serie or '-'"/></td></tr>
                            <tr><th>Date d'Acquisition</th><td><t t-esc="doc.date_acquisition or '-'"/></td></tr>
                            <tr><th>Valeur d'Achat (FCFA)</th><td><t t-esc="doc.valeur_achat"/></td></tr>
                            <tr><th>État</th><td><t t-esc="doc.state"/></td></tr>
                            <tr><th>Employé Affecté</th><td><t t-esc="doc.employee_id.name or '-'"/></td></tr>
                            <tr><th>Localisation</th><td><t t-esc="doc.localisation or '-'"/></td></tr>
                        </table>
                        <t t-if="doc.intervention_ids">
                            <h4 class="mt-4">Historique des Interventions</h4>
                            <table class="table table-sm table-bordered">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Titre</th>
                                        <th>Type</th>
                                        <th>Date</th>
                                        <th>État</th>
                                        <th>Coût (FCFA)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.intervention_ids" t-as="inter">
                                        <tr>
                                            <td><t t-esc="inter.name"/></td>
                                            <td><t t-esc="inter.type_intervention"/></td>
                                            <td><t t-esc="inter.date_debut"/></td>
                                            <td><t t-esc="inter.state"/></td>
                                            <td><t t-esc="inter.cout"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <!-- ========== RAPPORT 2 : Inventaire Global ========== -->
    <record id="action_report_it_inventaire" model="ir.actions.report">
        <field name="name">Inventaire du Parc</field>
        <field name="model">it.equipement</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_parc.report_it_inventaire_template</field>
        <field name="report_file">it_parc.report_it_inventaire_template</field>
        <field name="binding_model_id" ref="model_it_equipement"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_it_inventaire_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2 class="text-center mb-4">Inventaire du Parc Informatique — TECHPARK CI</h2>
                    <table class="table table-bordered table-sm">
                        <thead class="table-dark">
                            <tr>
                                <th>Référence</th>
                                <th>Nom</th>
                                <th>Type</th>
                                <th>Marque</th>
                                <th>Localisation</th>
                                <th>Employé</th>
                                <th>État</th>
                                <th>Valeur (FCFA)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="doc">
                                <tr>
                                    <td><t t-esc="doc.reference or '-'"/></td>
                                    <td><t t-esc="doc.name"/></td>
                                    <td><t t-esc="doc.type_equipement"/></td>
                                    <td><t t-esc="doc.marque or '-'"/></td>
                                    <td><t t-esc="doc.localisation or '-'"/></td>
                                    <td><t t-esc="doc.employee_id.name or '-'"/></td>
                                    <td><t t-esc="doc.state"/></td>
                                    <td><t t-esc="doc.valeur_achat"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <!-- ========== RAPPORT 3 : Rapport Interventions ========== -->
    <record id="action_report_it_intervention" model="ir.actions.report">
        <field name="name">Rapport des Maintenances</field>
        <field name="model">it.intervention</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">it_parc.report_it_intervention_template</field>
        <field name="report_file">it_parc.report_it_intervention_template</field>
        <field name="binding_model_id" ref="model_it_intervention"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_it_intervention_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center mb-4">Rapport d'Intervention</h2>
                        <table class="table table-bordered">
                            <tr><th>Référence</th><td><t t-esc="doc.reference or '-'"/></td></tr>
                            <tr><th>Titre</th><td><t t-esc="doc.name"/></td></tr>
                            <tr><th>Équipement</th><td><t t-esc="doc.equipement_id.name"/></td></tr>
                            <tr><th>Technicien</th><td><t t-esc="doc.employee_id.name or '-'"/></td></tr>
                            <tr><th>Type</th><td><t t-esc="doc.type_intervention"/></td></tr>
                            <tr><th>Date Début</th><td><t t-esc="doc.date_debut"/></td></tr>
                            <tr><th>Date Fin</th><td><t t-esc="doc.date_fin or '-'"/></td></tr>
                            <tr><th>Durée (h)</th><td><t t-esc="doc.duree"/></td></tr>
                            <tr><th>Coût (FCFA)</th><td><t t-esc="doc.cout"/></td></tr>
                            <tr><th>État</th><td><t t-esc="doc.state"/></td></tr>
                        </table>
                        <t t-if="doc.description">
                            <h4 class="mt-3">Description</h4>
                            <p><t t-esc="doc.description"/></p>
                        </t>
                        <t t-if="doc.rapport">
                            <h4 class="mt-3">Rapport Technique</h4>
                            <p><t t-esc="doc.rapport"/></p>
                        </t>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>