<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_it_alerte_form" model="ir.ui.view">
        <field name="name">it.alerte.form</field>
        <field name="model">it.alerte</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_marquer_lu" string="Marquer Lu" type="object"
                            invisible="state != 'nouveau'"/>
                    <button name="action_traiter" string="Traiter" type="object"
                            class="btn-primary" invisible="state == 'traite'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="nouveau,lu,traite"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="type_alerte"/>
                            <field name="priorite" widget="priority"/>
                            <field name="date_alerte"/>
                        </group>
                        <group>
                            <field name="equipement_id"/>
                            <field name="contrat_id"/>
                        </group>
                    </group>
                    <field name="description"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_it_alerte_list" model="ir.ui.view">
        <field name="name">it.alerte.list</field>
        <field name="model">it.alerte</field>
        <field name="arch" type="xml">
            <list decoration-danger="priorite == '2'" decoration-warning="priorite == '1'">
                <field name="name"/>
                <field name="type_alerte"/>
                <field name="priorite" widget="priority"/>
                <field name="date_alerte"/>
                <field name="equipement_id"/>
                <field name="contrat_id"/>
                <field name="state" widget="badge"
                       decoration-danger="state == 'nouveau'"
                       decoration-warning="state == 'lu'"
                       decoration-success="state == 'traite'"/>
            </list>
        </field>
    </record>

    <record id="action_it_alerte" model="ir.actions.act_window">
        <field name="name">Alertes</field>
        <field name="res_model">it.alerte</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>